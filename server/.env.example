ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-secure
SESSION_SECRET=generate-a-long-random-string-here
PORT=3000
ALLOWED_ORIGIN=https://ladderice.co

# Optional Postmark defaults for the vote email flow.
# The app will map these into its SMTP settings on first boot if SMTP_* is empty.
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM_EMAIL=vote@ladderice.co
POSTMARK_FROM_NAME=Ladderice Campaign
POSTMARK_SMTP_HOST=smtp.postmarkapp.com
POSTMARK_SMTP_PORT=587
SITE_URL=https://ladderice.co
